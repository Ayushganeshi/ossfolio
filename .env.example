# Supabase — get these from your project dashboard: Settings → API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=   # only needed for server-side admin jobs — leave empty for now

# GitHub OAuth — only needed for local Supabase dev (supabase/config.toml)
# Create an OAuth app at https://github.com/settings/developers
# Callback URL: http://localhost:54321/auth/v1/callback
# GH_CLIENT_ID=
# GH_CLIENT_SECRET=

# Optional: AI features (Anthropic)
# ANTHROPIC_API_KEY=
